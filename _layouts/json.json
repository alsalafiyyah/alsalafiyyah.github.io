---
layout: null
robots: noindex
---
[
{% for post in site.posts %}
  {
    "no": {{ forloop.index }},
    "title": {{ post.title | jsonify }},
    "permalink": {{ post.url | jsonify }},
    "slug": {{ post.url | split: '/' | reject: '' | last | jsonify }},
    "url": {{ post.url | prepend: site.baseurl | prepend: site.url | jsonify }},
    "date": {{ post.date | date_to_xmlschema | jsonify }},
    "hijri": {{ post.hijri | jsonify }},
    "lang": {{ post.lang | jsonify }},
    "uid": {{ post.uid | jsonify }},
    "locale": {{ post.locale | jsonify }},
    "layout": {{ post.layout | jsonify }},
    "source": {{ post.source | jsonify }},
    "publisher": {{ post.publisher | jsonify }},
    "categories": {{ post.categories | jsonify }},
    "category": {{ post.category | jsonify }},
    "note": {{ post.note | jsonify }},
    "muftis": {{ post.muftis | jsonify }},
    "shaykh": {{ post.shaykh | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "translated_by": {{ post.translated_by | jsonify }},
    "article_taken_from": {{ post.article_taken_from | jsonify }},
    "audio": {{ post.mp3 | jsonify }},
    "excerpt": {{ post.excerpt | strip_html | strip_newlines | jsonify }},
    "content": {{ post.content | strip_newlines | jsonify }}
  }{% if forloop.last == false %},{% endif %}
{% endfor %}
]


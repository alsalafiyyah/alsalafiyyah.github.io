---
layout: null
permalink: /json/audios.json
---

[
  {% assign audio_posts = site.posts | where_exp: "post", "post.categories contains 'audios'" %}
  {% for post in audio_posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | jsonify }},
      "description": {{ post.summary | truncatewords: 20 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
